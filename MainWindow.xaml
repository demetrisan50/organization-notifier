<Window x:Class="organization_notifier.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:organization_notifier"
        mc:Ignorable="d"
        Title="Organization Notifier" Height="650" Width="500" Background="#F5F5F7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Organization Notifier" FontSize="28" FontWeight="Bold" Foreground="#1D1D1F" />
                <TextBlock x:Name="UserIdentityDisplay" Text="Logged in as: ..." FontSize="14" Foreground="#86868B" Margin="0,5,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Width="30" Height="30" Click="HelpButton_Click" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Help &amp; Documentation">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E8E8ED" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D2D2D7" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock Text="?" FontWeight="Bold" Foreground="#1D1D1F" />
            </Button>
            
            <!-- Generic Error -->
            <TextBlock x:Name="GenericErrorText" Grid.Row="1" Grid.ColumnSpan="2" Text="Please fix the errors below before proceeding." Foreground="#D70015" FontWeight="SemiBold" Visibility="Collapsed" Margin="0,15,0,0" />
        </Grid>

        <!-- Form Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Notification Title" Margin="0,0,0,5" Foreground="#1D1D1F" FontWeight="SemiBold" />
                <TextBox x:Name="TitleInput" Padding="10" Margin="0,0,0,2" BorderThickness="1" BorderBrush="#D2D2D7" TextChanged="ValidateInput_Changed" LostFocus="ValidateInput_Blur" />
                <TextBlock x:Name="TitleError" Text="Title is required" Foreground="#D70015" FontSize="11" Margin="0,0,0,15" Visibility="Collapsed" />

                <TextBlock Text="Message" Margin="0,0,0,5" Foreground="#1D1D1F" FontWeight="SemiBold" />
                <TextBox x:Name="MessageInput" Padding="10" Margin="0,0,0,2" Height="80" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="1" BorderBrush="#D2D2D7" TextChanged="ValidateInput_Changed" LostFocus="ValidateInput_Blur" />
                <TextBlock x:Name="MessageError" Text="Message is required" Foreground="#D70015" FontSize="11" Margin="0,0,0,15" Visibility="Collapsed" />

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Duration" Margin="0,0,0,5" Foreground="#1D1D1F" FontWeight="SemiBold" />
                        <ComboBox x:Name="DurationDropdown" Padding="5">
                            <ComboBoxItem Content="Short" />
                            <ComboBoxItem Content="Long" IsSelected="True" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="App ID" Margin="0,0,0,5" Foreground="#1D1D1F" FontWeight="SemiBold" />
                        <TextBox x:Name="AppIdInput" Padding="8" BorderThickness="1" BorderBrush="#D2D2D7" Text="IT Support Team" TextChanged="ValidateInput_Changed" LostFocus="ValidateInput_Blur" />
                        <TextBlock x:Name="AppIdError" Text="App ID is required" Foreground="#D70015" FontSize="11" Margin="0,0,0,0" Visibility="Collapsed" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Icon" Margin="0,0,0,5" Foreground="#1D1D1F" FontWeight="SemiBold" />
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="IconPathDisplay" Grid.Column="0" Padding="10" IsReadOnly="True" Margin="0,0,10,0" BorderThickness="1" BorderBrush="#D2D2D7" Text="No file selected..." />
                    <ComboBox x:Name="IconDropdown" Grid.Column="1" Width="150" Margin="0,0,10,0" SelectionChanged="IconDropdown_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Image Source="{Binding ImageSource}" Width="20" Height="20" Margin="5,0,10,0" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="#1D1D1F" />
                            </StackPanel>
                        </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Browse" Grid.Column="2" Padding="15,5" Click="BrowseButton_Click" Background="#E8E8ED" BorderThickness="0" Cursor="Hand" />
                </Grid>
                <TextBlock x:Name="IconError" Text="Icon selection is required" Foreground="#D70015" FontSize="11" Margin="0,0,0,15" Visibility="Collapsed" />

                <!-- Quick Scenarios -->
                <GroupBox Header="Quick Scenarios (Save/Run)" Margin="0,10,0,0" Padding="10">
                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ScenariosList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#1D1D1F" />
                                        <Button Grid.Column="1" Content="Save Current" Click="SaveScenario_Click" Tag="{Binding}" Margin="0,0,8,0" Padding="8,3" Background="#F2F2F7" BorderThickness="0" FontSize="11" Cursor="Hand" />
                                        <Button Grid.Column="2" Content="Run" Click="RunScenario_Click" Tag="{Binding}" Padding="15,3" Background="#34C759" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Log Output -->
        <GroupBox Grid.Row="2" Header="Execution Log" Margin="0,10,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogOutput" TextWrapping="Wrap" FontFamily="Consolas" Padding="10" FontSize="12" Foreground="#333" />
            </ScrollViewer>
        </GroupBox>

        <!-- Actions -->
        <Button Grid.Row="3" Content="Save &amp; Execute" Click="ExecuteButton_Click" Padding="20,12" Background="#0071E3" Foreground="White" FontWeight="Bold" FontSize="16" BorderThickness="0" Cursor="Hand" />
    </Grid>
</Window>
